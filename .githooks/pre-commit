#!/usr/bin/env bash
# Pre-commit hook: cargo fmt --check + cargo clippy.
# Runs only when Rust sources or Cargo.toml are staged, to stay out of the way
# of documentation-only or rules.json-only commits.
#
# Activate once per clone with:
#   git config core.hooksPath .githooks

set -euo pipefail

staged_rust=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '(\.rs$|^Cargo\.(toml|lock)$)' || true)

if [[ -z "$staged_rust" ]]; then
    exit 0
fi

echo "pre-commit: running cargo fmt --check …"
if ! cargo fmt --all -- --check; then
    echo
    echo "✗ Formatting issues. Run 'cargo fmt --all' and re-stage."
    exit 1
fi

echo "pre-commit: running cargo clippy …"
if ! cargo clippy --all-targets --quiet -- -D warnings; then
    echo
    echo "✗ clippy reported warnings/errors (treated as errors)."
    exit 1
fi

echo "pre-commit: ok"
