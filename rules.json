{
  "version": 1,
  "rules": [
    {"pattern": "~/.cache", "type": "cache", "behavior": "skip"},
    {"pattern": "~/.local/share/Trash", "type": "trash", "behavior": "skip"},
    {"pattern": "~/snap", "type": "system", "behavior": "skip"},
    {"pattern": "~/.var/app", "type": "flatpak", "behavior": "skip"},
    {"pattern": "~/.steam/steam/steamapps/common", "type": "games", "behavior": "index"},
    {"pattern": "~/.local/share/Steam/steamapps/common", "type": "games", "behavior": "index"},
    {"pattern": "**/node_modules", "type": "dependencies", "behavior": "skip"},
    {"pattern": "**/target/debug", "type": "build", "behavior": "skip"},
    {"pattern": "**/target/release", "type": "build", "behavior": "skip"},
    {"pattern": "**/__pycache__", "type": "cache", "behavior": "skip"},
    {"pattern": "**/.venv", "type": "dependencies", "behavior": "skip"},
    {"pattern": "**/venv", "type": "dependencies", "behavior": "skip"},
    {"pattern": "**/.tox", "type": "build", "behavior": "skip"},
    {"pattern": "**/.pytest_cache", "type": "cache", "behavior": "skip"},
    {"pattern": "**/.mypy_cache", "type": "cache", "behavior": "skip"},
    {"pattern": "**/build", "type": "build", "behavior": "skip"},
    {"pattern": "**/dist", "type": "build", "behavior": "skip"},
    {"pattern": "**/*.egg-info", "type": "build", "behavior": "skip"},
    {"pattern": "**/.gradle", "type": "build", "behavior": "skip"},
    {"pattern": "**/.idea", "type": "ide", "behavior": "skip"},
    {"pattern": "**/.vscode", "type": "ide", "behavior": "skip"},
    {"pattern": "**/vendor", "type": "dependencies", "behavior": "skip"},
    {"pattern": "**/Pods", "type": "dependencies", "behavior": "skip"},
    {"pattern": "**/.DS_Store", "type": "system", "behavior": "skip"},
    {"pattern": "**/Thumbs.db", "type": "system", "behavior": "skip"},
    {"pattern": "~/.ssh", "type": "config", "behavior": "skip", "privacy": "confidential"},
    {"pattern": "~/.gnupg", "type": "config", "behavior": "skip", "privacy": "confidential"},
    {"pattern": "~/.password-store", "type": "secrets", "behavior": "skip", "privacy": "confidential"},
    {"pattern": "~/.config", "type": "config", "behavior": "shallow"},
    {"pattern": "~/.local", "type": "local", "behavior": "shallow"},
    {"pattern": "/proc", "type": "system", "behavior": "skip"},
    {"pattern": "/sys", "type": "system", "behavior": "skip"},
    {"pattern": "/dev", "type": "system", "behavior": "skip"},
    {"pattern": "/run", "type": "system", "behavior": "skip"},
    {"pattern": "/tmp", "type": "temp", "behavior": "skip"},
    {"pattern": "/var/tmp", "type": "temp", "behavior": "skip"},
    {"pattern": "/lost+found", "type": "system", "behavior": "skip"},
    {"pattern": "/boot", "type": "system", "behavior": "skip"},
    {"pattern": "/usr", "type": "system", "behavior": "skip"},
    {"pattern": "/bin", "type": "system", "behavior": "skip"},
    {"pattern": "/sbin", "type": "system", "behavior": "skip"},
    {"pattern": "/lib", "type": "system", "behavior": "skip"},
    {"pattern": "/lib64", "type": "system", "behavior": "skip"},
    {"pattern": "/opt", "type": "system", "behavior": "skip"},
    {"pattern": "/etc", "type": "system", "behavior": "skip"},
    {"pattern": "/var/lib", "type": "system", "behavior": "skip"},
    {"pattern": "/var/log", "type": "logs", "behavior": "skip"},
    {"pattern": "/var/cache", "type": "cache", "behavior": "skip"}
  ],
  "contexts": [
    {"pattern": "~/Music", "structure": "music", "levels": ["library", "artist", "album"]},
    {"pattern": "~/Pictures", "structure": "photos", "levels": ["library", "album"]},
    {"pattern": "~/Photos", "structure": "photos", "levels": ["library", "album"]},
    {"pattern": "~/Videos", "structure": "videos", "levels": ["library", "series", "season"]},
    {"pattern": "~/Movies", "structure": "videos", "levels": ["library", "series", "season"]},
    {"pattern": "~/Projects", "structure": "projects", "levels": ["folder", "project"]},
    {"pattern": "~/src", "structure": "projects", "levels": ["folder", "project"]},
    {"pattern": "~/code", "structure": "projects", "levels": ["folder", "project"]},
    {"pattern": "~/Games", "structure": "games", "levels": ["library", "game"]},
    {"pattern": "~/Documents", "structure": "documents", "levels": ["folder", "category"]}
  ]
}
