{
  "version": 3,

  "skip": [],

  "privacy": [
    {"pattern": "~/.ssh", "level": "confidential"},
    {"pattern": "~/.gnupg", "level": "confidential"},
    {"pattern": "~/.password-store", "level": "confidential"},
    {"pattern": "~/Documents/Taxes", "level": "confidential"},
    {"pattern": "~/Documents/Medical", "level": "confidential"},
    {"pattern": "~/Pictures", "level": "personal"},
    {"pattern": "~/Photos", "level": "personal"},
    {"pattern": "~/Documents", "level": "personal"},
    {"pattern": "~/Downloads", "level": "personal"}
  ],

  "groups": {
    "game_stores": [
      "gog", "steam", "epic-games", "epic-games-store", "humblebundle",
      "itchio", "battlenet", "ea-app", "ea-app-broken", "ea-app-flatpak",
      "uplay", "gog-galaxy", "Heroic", "gamejolt"
    ],
    "game_platforms": [
      "dos", "windows", "linux", "arcade", "mame", "scummvm",
      "amiga", "Amiga", "amstrad", "Amstrad", "apple", "Apple",
      "atari", "Atari", "commodore", "intellivision",
      "msx", "nec", "ngage", "pc98", "phillips-cdi",
      "xbox", "xbox-360", "asgard"
    ],
    "platform_vendors": ["nintendo", "sega", "sony"],
    "emulators": [
      "cemu", "mesen", "xenia-emu", "pcem", "mame", "scummvm"
    ],
    "home_emulators": [
      ".citra", ".dolphin-emu", ".dolphin-emu-master", ".pcsx2", ".ppsspp",
      ".mupen64plus", ".mame", ".scummvm", ".dosbox", ".dosbox-staging",
      ".dgen", ".snes9x", ".zsnes", ".nestopia", ".higan", ".redream",
      ".duckstation", ".melonds", ".rpcs3", ".yuzu", ".ryujinx",
      ".vice", ".fs-uae", ".openmsx", ".puNES", ".fceux",
      ".mednafen", ".bsnes", ".mgba", ".vbam", ".desmume", ".supermodel",
      ".hatari", ".stella", ".pcem"
    ]
  },

  "match": [
    {"contains": "Cargo.toml",       "base": "code",  "tags": ["lang=rust"], "stop": true},
    {"contains": "package.json",     "base": "code",  "tags": ["lang=js"], "stop": true},
    {"contains": "pyproject.toml",   "base": "code",  "tags": ["lang=python"], "stop": true},
    {"contains": "setup.py",         "base": "code",  "tags": ["lang=python"], "stop": true},
    {"contains": "go.mod",           "base": "code",  "tags": ["lang=go"], "stop": true},
    {"contains": "Gemfile",          "base": "code",  "tags": ["lang=ruby"], "stop": true},
    {"contains": "pom.xml",          "base": "code",  "tags": ["lang=java"], "stop": true},
    {"contains": "build.gradle",     "base": "code",  "tags": ["lang=java"], "stop": true},
    {"contains": "CMakeLists.txt",   "base": "code",  "tags": ["lang=cpp"], "stop": true},
    {"contains": "Makefile",         "base": "code",  "stop": true},
    {"contains": ".git",             "base": "code",  "tags": ["vcs=git"], "stop": true},

    {"path": "~/Games/{store}",  "contains": "drive_c",
     "base": "game", "tags": ["store={store}", "runtime=wine"], "stop": true,
     "where": {"store": "game_stores"}},
    {"path": "~/Games/{store}/{title}",  "contains": "drive_c",
     "base": "game", "tags": ["store={store}", "title={title}", "runtime=wine"], "stop": true,
     "where": {"store": "game_stores"}},

    {"contains": "steam_appid.txt",  "base": "game",  "tags": ["runtime=steam"], "stop": true},
    {"contains": "appmanifest.acf",  "base": "game",  "tags": ["runtime=steam"], "stop": true},

    {"path": "**/node_modules",      "base": "cache", "tags": ["ephemeral", "kind=node_modules"], "stop": true},
    {"path": "**/__pycache__",       "base": "cache", "tags": ["ephemeral", "kind=pycache"], "stop": true},
    {"path": "**/.venv",             "base": "cache", "tags": ["ephemeral", "kind=venv"], "stop": true},
    {"path": "**/venv",              "base": "cache", "tags": ["ephemeral", "kind=venv"], "stop": true},
    {"path": "**/target/debug",      "base": "cache", "tags": ["ephemeral", "kind=rust-build"], "stop": true},
    {"path": "**/target/release",    "base": "cache", "tags": ["ephemeral", "kind=rust-build"], "stop": true},
    {"path": "**/.tox",              "base": "cache", "tags": ["ephemeral"], "stop": true},
    {"path": "**/.pytest_cache",     "base": "cache", "tags": ["ephemeral"], "stop": true},
    {"path": "**/.mypy_cache",       "base": "cache", "tags": ["ephemeral"], "stop": true},
    {"path": "**/.gradle",           "base": "cache", "tags": ["ephemeral"], "stop": true},
    {"path": "**/.idea",             "base": "cache", "tags": ["kind=ide"], "stop": true},
    {"path": "**/.vscode",           "base": "cache", "tags": ["kind=ide"], "stop": true},

    {"path": "~/Music",                                "base": "audio", "tags": ["library"]},
    {"path": "~/Music/{artist}",                       "base": "audio", "tags": ["artist={artist}"]},
    {"path": "~/Music/{artist}/{album}",               "base": "audio", "tags": ["artist={artist}", "album={album}"], "stop": true},

    {"path": "~/Pictures",                             "base": "image", "tags": ["library"]},
    {"path": "~/Pictures/{album}",                     "base": "image", "tags": ["album={album}"], "stop": true},
    {"path": "~/Photos",                               "base": "image", "tags": ["library"]},
    {"path": "~/Photos/{album}",                       "base": "image", "tags": ["album={album}"], "stop": true},

    {"path": "~/Videos",                               "base": "video", "tags": ["library"]},
    {"path": "~/Videos/{series}",                      "base": "video", "tags": ["series={series}"]},
    {"path": "~/Videos/{series}/{season}",             "base": "video", "tags": ["series={series}", "season={season}"], "stop": true},
    {"path": "~/Movies",                               "base": "video", "tags": ["library"]},
    {"path": "~/Movies/{series}",                      "base": "video", "tags": ["series={series}"]},
    {"path": "~/Movies/{series}/{season}",             "base": "video", "tags": ["series={series}", "season={season}"], "stop": true},

    {"path": "~/Documents",                            "base": "document", "tags": ["library"]},
    {"path": "~/Documents/{category}",                 "base": "document", "tags": ["category={category}"], "stop": true},

    {"path": "~/Projects",                             "base": "code", "tags": ["library"]},
    {"path": "~/src",                                  "base": "code", "tags": ["library"]},
    {"path": "~/code",                                 "base": "code", "tags": ["library"]},

    {"path": "~/Games",                                "base": "game", "tags": ["library"]},

    {"path": "~/Games/{name}",
      "base": "emulator", "tags": ["name={name}"], "stop": true,
      "where": {"name": "emulators"}},

    {"path": "~/Games/{store}",
      "base": "game", "tags": ["store={store}"],
      "where": {"store": "game_stores"}},
    {"path": "~/Games/{store}/{title}",
      "base": "game", "tags": ["store={store}", "title={title}"], "stop": true,
      "where": {"store": "game_stores"}},

    {"path": "~/Games/{vendor}",
      "base": "game", "tags": ["vendor={vendor}"],
      "where": {"vendor": "platform_vendors"}},
    {"path": "~/Games/{vendor}/{name}",
      "base": "emulator", "tags": ["vendor={vendor}", "name={name}"], "stop": true,
      "where": {"vendor": "platform_vendors", "name": "emulators"}},
    {"path": "~/Games/{vendor}/{platform}",
      "base": "game", "tags": ["vendor={vendor}", "platform={platform}"],
      "where": {"vendor": "platform_vendors"}},
    {"path": "~/Games/{vendor}/{platform}/{title}",
      "base": "game", "tags": ["vendor={vendor}", "platform={platform}", "title={title}"], "stop": true,
      "where": {"vendor": "platform_vendors"}},

    {"path": "~/Games/{platform}",
      "base": "game", "tags": ["platform={platform}"],
      "where": {"platform": "game_platforms"}},
    {"path": "~/Games/{platform}/{title}",
      "base": "game", "tags": ["platform={platform}", "title={title}"], "stop": true,
      "where": {"platform": "game_platforms"}},

    {"path": "~/.steam/steam/steamapps/common",                 "base": "game", "tags": ["store=steam"]},
    {"path": "~/.steam/steam/steamapps/common/{title}",         "base": "game", "tags": ["store=steam", "title={title}"], "stop": true},
    {"path": "~/.local/share/Steam/steamapps/common",           "base": "game", "tags": ["store=steam"]},
    {"path": "~/.local/share/Steam/steamapps/common/{title}",   "base": "game", "tags": ["store=steam", "title={title}"], "stop": true},

    {"path": "~/Desktop",                              "base": "document", "tags": ["kind=desktop"], "stop": true},
    {"path": "~/Downloads",                            "base": "document", "tags": ["kind=downloads"], "stop": true},
    {"path": "~/Images",                               "base": "image",    "tags": ["library"]},
    {"path": "~/Images/{album}",                       "base": "image",    "tags": ["album={album}"], "stop": true},
    {"path": "~/Screenshots",                          "base": "image",    "tags": ["kind=screenshots"], "stop": true},
    {"path": "~/Nextcloud",                            "base": "cache",    "tags": ["sync=nextcloud"], "stop": true},
    {"path": "~/Dropbox",                              "base": "cache",    "tags": ["sync=dropbox"], "stop": true},
    {"path": "~/Templates",                            "base": "document", "tags": ["kind=templates"], "stop": true},
    {"path": "~/Thunderbird",                          "base": "application", "tags": ["app=thunderbird"], "stop": true},
    {"path": "~/Recipes",                              "base": "document", "tags": ["kind=recipes"], "stop": true},
    {"path": "~/Software",                             "base": "application", "tags": ["kind=local-apps"], "stop": true},
    {"path": "~/JoplinBackup",                         "base": "archive",  "tags": ["app=joplin", "kind=backup"], "stop": true},

    {"path": "~/.cache",                               "base": "cache",    "stop": true},
    {"path": "~/.local",                               "base": "system"},
    {"path": "~/.local/share",                         "base": "system"},
    {"path": "~/.local/share/{app}",                   "base": "application", "tags": ["app={app}"], "stop": true},
    {"path": "~/.local/{subdir}",                      "base": "system",   "stop": true},
    {"path": "~/.local/share/Trash",                   "base": "cache",    "tags": ["ephemeral"], "stop": true},
    {"path": "~/.config",                              "base": "config"},
    {"path": "~/.config/{app}",                        "base": "config",   "tags": ["app={app}"], "stop": true},
    {"path": "~/.mozilla",                             "base": "application", "tags": ["app=firefox"], "stop": true},
    {"path": "~/.thunderbird",                         "base": "application", "tags": ["app=thunderbird"], "stop": true},
    {"path": "~/.vscode",                              "base": "config",   "tags": ["app=vscode"], "stop": true},
    {"path": "~/.vscode-server",                       "base": "cache",    "tags": ["app=vscode-server"], "stop": true},
    {"path": "~/.cargo",                               "base": "cache",    "tags": ["toolchain=rust"], "stop": true},
    {"path": "~/.rustup",                              "base": "cache",    "tags": ["toolchain=rust"], "stop": true},
    {"path": "~/.npm",                                 "base": "cache",    "tags": ["toolchain=node"], "stop": true},
    {"path": "~/.nvm",                                 "base": "cache",    "tags": ["toolchain=node"], "stop": true},
    {"path": "~/.pyenv",                               "base": "cache",    "tags": ["toolchain=python"], "stop": true},
    {"path": "~/.rbenv",                               "base": "cache",    "tags": ["toolchain=ruby"], "stop": true},
    {"path": "~/.gem",                                 "base": "cache",    "tags": ["toolchain=ruby"], "stop": true},
    {"path": "~/go",                                   "base": "cache",    "tags": ["toolchain=go"]},
    {"path": "~/.docker",                              "base": "config",   "tags": ["app=docker"], "stop": true},
    {"path": "~/.gnupg",                               "base": "config",   "tags": ["app=gnupg"], "stop": true},
    {"path": "~/.ssh",                                 "base": "config",   "tags": ["app=ssh"], "stop": true},
    {"path": "~/.password-store",                      "base": "config",   "tags": ["app=pass"], "stop": true},
    {"path": "~/.wine",                                "base": "application", "tags": ["runtime=wine"], "stop": true},
    {"path": "~/snap",                                 "base": "application", "tags": ["runtime=snap"], "stop": true},
    {"path": "~/.var/app",                             "base": "application", "tags": ["runtime=flatpak"], "stop": true},
    {"path": "~/.var",                                 "base": "system",   "stop": true},

    {"path": "~/{app}",
     "base": "emulator", "tags": ["name={app}"], "stop": true,
     "where": {"app": "home_emulators"}},

    {"path": "~/.android",                             "base": "cache",       "tags": ["toolchain=android"], "stop": true},
    {"path": "~/.aspnet",                              "base": "config",      "tags": ["app=aspnet"], "stop": true},
    {"path": "~/.aws",                                 "base": "config",      "tags": ["app=aws"], "stop": true},
    {"path": "~/.bun",                                 "base": "cache",       "tags": ["toolchain=bun"], "stop": true},
    {"path": "~/.conda",                               "base": "cache",       "tags": ["toolchain=conda"], "stop": true},
    {"path": "~/.dart",                                "base": "cache",       "tags": ["toolchain=dart"], "stop": true},
    {"path": "~/.dart-cli-completion",                 "base": "cache",       "tags": ["toolchain=dart"], "stop": true},
    {"path": "~/.dart-tool",                           "base": "cache",       "tags": ["toolchain=dart"], "stop": true},
    {"path": "~/.dartServer",                          "base": "cache",       "tags": ["toolchain=dart"], "stop": true},
    {"path": "~/.dotnet",                              "base": "cache",       "tags": ["toolchain=dotnet"], "stop": true},
    {"path": "~/.flutter-devtools",                    "base": "cache",       "tags": ["toolchain=flutter"], "stop": true},
    {"path": "~/.fvm_flutter",                         "base": "cache",       "tags": ["toolchain=flutter"], "stop": true},
    {"path": "~/.helm",                                "base": "config",      "tags": ["app=helm"], "stop": true},
    {"path": "~/.ipython",                             "base": "config",      "tags": ["app=ipython"], "stop": true},
    {"path": "~/.java",                                "base": "cache",       "tags": ["toolchain=java"], "stop": true},
    {"path": "~/.jupyter",                             "base": "config",      "tags": ["app=jupyter"], "stop": true},
    {"path": "~/.kde",                                 "base": "config",      "tags": ["app=kde"], "stop": true},
    {"path": "~/.mono",                                "base": "cache",       "tags": ["toolchain=mono"], "stop": true},
    {"path": "~/.mozbuild",                            "base": "cache",       "tags": ["toolchain=firefox"], "stop": true},
    {"path": "~/.npm-global",                          "base": "cache",       "tags": ["toolchain=node"], "stop": true},
    {"path": "~/.nuget",                               "base": "cache",       "tags": ["toolchain=dotnet"], "stop": true},
    {"path": "~/.nuxt",                                "base": "cache",       "tags": ["toolchain=node"], "stop": true},
    {"path": "~/.nv",                                  "base": "cache",       "tags": ["toolchain=nvidia"], "stop": true},
    {"path": "~/.nx",                                  "base": "cache",       "tags": ["toolchain=nx"], "stop": true},
    {"path": "~/.pub-cache",                           "base": "cache",       "tags": ["toolchain=dart"], "stop": true},
    {"path": "~/.putty",                               "base": "config",      "tags": ["app=putty"], "stop": true},
    {"path": "~/.qt",                                  "base": "config",      "tags": ["toolchain=qt"], "stop": true},
    {"path": "~/.ruff_cache",                          "base": "cache",       "tags": ["toolchain=ruff"], "stop": true},
    {"path": "~/.skiko",                               "base": "cache",       "tags": ["toolchain=skia"], "stop": true},
    {"path": "~/.tauri",                               "base": "cache",       "tags": ["toolchain=tauri"], "stop": true},
    {"path": "~/.templateengine",                      "base": "cache",       "tags": ["toolchain=dotnet"], "stop": true},
    {"path": "~/.vcpkg",                               "base": "cache",       "tags": ["toolchain=vcpkg"], "stop": true},
    {"path": "~/.virtualenvs",                         "base": "cache",       "tags": ["toolchain=python"], "stop": true},
    {"path": "~/.yarn",                                "base": "cache",       "tags": ["toolchain=node"], "stop": true},
    {"path": "~/.fltk",                                "base": "config",      "tags": ["toolchain=fltk"], "stop": true},
    {"path": "~/.vim",                                 "base": "config",      "tags": ["app=vim"], "stop": true},
    {"path": "~/.zsh",                                 "base": "config",      "tags": ["app=zsh"], "stop": true},
    {"path": "~/.themes",                              "base": "config",      "tags": ["kind=themes"], "stop": true},
    {"path": "~/.thumbnails",                          "base": "cache",       "tags": ["ephemeral"], "stop": true},
    {"path": "~/.Trash",                               "base": "cache",       "tags": ["ephemeral", "kind=trash"], "stop": true},
